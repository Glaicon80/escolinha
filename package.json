{
  "name": "escolinha",
  "version": "1.0.0",
  "description": "Sistema de gestão escolar com autenticação",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js", 
    "dev": "nodemon src/server.js",
    "test": "jest --runInBand",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration --runInBand",
    "test:watch": "jest --watch"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": ["./tests/setup.js"], 
    "testTimeout": 30000,
    "testMatch": ["**/tests/*.test.js"], 
    "collectCoverage": true
  },
  "keywords": ["nodejs", "express", "mysql", "docker"],
  "author": "glaicon",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "body-parser": "^2.2.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "mysql2": "^3.18.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3",
    "dotenv": "^16.3.1"
  }
}
